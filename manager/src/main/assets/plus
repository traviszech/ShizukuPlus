#!/system/bin/sh
BASEDIR=$(dirname "$0")
# On a real device, this script would find the manager's APK and use it
# For the purpose of the Plus helper, we use the same loader as rish
DEX="$BASEDIR"/rish_shizuku.dex

if [ ! -f "$DEX" ]; then
  # Fallback: find it in typical installation paths
  DEX="/data/local/tmp/rish_shizuku.dex"
fi

if [ ! -f "$DEX" ]; then
  echo "Error: rish_shizuku.dex not found."
  echo "Please ensure Shizuku is correctly installed and configured."
  exit 1
fi

# Ensure dex is not writable on Android 14+
if [ $(getprop ro.build.version.sdk) -ge 34 ]; then
  chmod 400 $DEX 2>/dev/null
fi

# We use the loader but tell it to load our PlusShell instead of the standard Shell
# This requires ShizukuShellLoader to be able to load arbitrary classes, 
# or we use a custom RISH_APPLICATION_ID.
[ -z "$RISH_APPLICATION_ID" ] && export RISH_APPLICATION_ID="moe.shizuku.privileged.api"

/system/bin/app_process -Djava.class.path="$DEX" -Dshizuku.cmd=plus /system/bin --nice-name=plus rikka.shizuku.shell.ShizukuShellLoader "$@"
